# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── Crawler (Optional) ─────────────────────────────────────────
# 天气采集默认使用 Open-Meteo 免费 API，无需配置
# 以下 Cookie 用于增强微博/抖音/小红书抓取稳定性，不填也能运行
CRAWLER_WEIBO_COOKIE=     # 微博 Cookie（可选）
CRAWLER_DOUYIN_COOKIE=    # 抖音 Cookie（可选）
CRAWLER_XHS_COOKIE=       # 小红书 Cookie（可选）
CRAWLER_WEATHER_API_KEY=  # 和风天气 API Key（可选，默认使用 Open-Meteo）
